# Authentication
# SECURITY: Generate a strong random token using: openssl rand -hex 32
AUTH_TOKEN=your-secure-random-token-here-change-this

# Amazon configuration
AMAZON_DOMAIN=amazon.com

# Optional browser override for local development
CHROME_EXECUTABLE_PATH=

# Stateless session signing secret
# Defaults to AUTH_TOKEN when omitted, but a separate secret is recommended.
SESSION_SECRET=your-optional-session-secret
